.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.item-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}
.type-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.tag-lost { background: #fff1f0; color: #f5222d; }
.tag-found { background: #f6ffed; color: #52c41a; }

.status-bar {
  margin-bottom: 20rpx;
}
.status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.status-0 { background: #fff7e6; color: #fa8c16; }
.status-1 { background: #f6ffed; color: #52c41a; }
.status-2 { background: #fff1f0; color: #f5222d; }
.status-3 { background: #f5f5f5; color: #999; }

.detail-body {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 16rpx;
  margin-bottom: 20rpx;
}
.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}
.info-label {
  width: 140rpx;
  color: #999;
  flex-shrink: 0;
}
.info-value {
  color: #333;
  flex: 1;
}

.desc-section {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
}
.desc-label {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}
.desc-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  display: block;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}
.action-btn {
  flex: 1;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 18rpx 0;
  border: none;
}
.edit-btn {
  background: #2F5496;
  color: #fff;
}
.delete-btn {
  background: #fff;
  color: #f5222d;
  border: 2rpx solid #f5222d;
}

.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #bbb;
  font-size: 28rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #2F5496;
}

.form-item {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}
.form-input {
  background: #f9f9f9;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}
.form-textarea {
  background: #f9f9f9;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  height: 180rpx;
}
.picker-value {
  background: #f9f9f9;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #555;
}

.submit-btn {
  width: 100%;
  background: #2F5496;
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  margin-top: 16rpx;
  border: none;
}
.submit-btn[loading] {
  opacity: 0.8;
}
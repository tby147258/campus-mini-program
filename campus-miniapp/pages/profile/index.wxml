<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default_avatar.png'}}" mode="aspectFill" />
    </view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || userInfo.nickname || '未登录'}}</text>
      <text class="user-desc">欢迎使用校园综合服务</text>
    </view>
  </view>

  <!-- 功能菜单列表 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="goMyPosts">
      <text class="menu-icon menu-icon-posts">📋</text>
      <text class="menu-text">我的发布</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMyRepairs">
      <text class="menu-icon menu-icon-repair">🔧</text>
      <text class="menu-text">我的报修</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goFeedback">
      <text class="menu-icon menu-icon-feedback">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon menu-icon-about">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="logout">
    <text>退出登录</text>
  </view>

  <!-- 我的发布弹窗 -->
  <view class="modal-overlay" wx:if="{{showPosts}}" bindtap="hidePosts">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">我的发布</text>
        <text class="modal-close" bindtap="hidePosts">×</text>
      </view>
      <view class="modal-body">
        <view wx:if="{{myPosts.length > 0}}">
          <view class="post-item" wx:for="{{myPosts}}" wx:key="id" bindtap="goPostDetail" data-id="{{item.id}}">
            <view class="post-header">
              <text class="post-name">{{item.itemName}}</text>
              <text class="post-status status-{{item.status}}">
                <text wx:if="{{item.status === 0}}">待审核</text>
                <text wx:elif="{{item.status === 1}}">已发布</text>
                <text wx:elif="{{item.status === 2}}">已驳回</text>
                <text wx:else>已关闭</text>
              </text>
            </view>
            <text class="post-time">{{item.createdAt}}</text>
          </view>
        </view>
        <view wx:else class="empty-in-modal">
          <text>暂无发布记录</text>
        </view>
      </view>
    </view>
  </view>
</view>
.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #2F5496, #4a7bc4);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 30rpx;
  color: #fff;
}
.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.6);
  flex-shrink: 0;
}
.avatar {
  width: 100%;
  height: 100%;
}
.user-info {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.nickname {
  font-size: 36rpx;
  font-weight: 600;
}
.user-desc {
  font-size: 24rpx;
  opacity: 0.8;
}

.menu-group {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  position: relative;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}
.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: bold;
}
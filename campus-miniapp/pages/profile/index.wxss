.profile-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.6);
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-info {
  margin-left: 24rpx;
  flex: 1;
  min-width: 0;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
}

.user-desc {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
  display: block;
}

.login-btn {
  margin-left: auto;
  background: rgba(255,255,255,0.25);
  border: 2rpx solid rgba(255,255,255,0.6);
  border-radius: 32rpx;
  padding: 12rpx 32rpx;
  flex-shrink: 0;
}

.login-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

/* 完善资料表单 */
.profile-form {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-top: 16rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

/* 功能菜单 */
.menu-list {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #333;
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* 退出登录按钮 */
.logout-btn {
  width: calc(100% - 48rpx);
  margin: 48rpx 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #e74c3c;
  border-radius: 16rpx;
  font-size: 30rpx;
  border: 2rpx solid #e74c3c;
}

.logout-btn::after {
  border: none;
}
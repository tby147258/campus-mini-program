.swiper { height: 320rpx; margin-bottom: 20rpx; border-radius: 16rpx; overflow: hidden; }
.swiper-img { width: 100%; height: 100%; }
.weather-card { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }
.weather-main { display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 8rpx; }
.weather-temp { font-size: 48rpx; font-weight: bold; }
.weather-text { font-size: 28rpx; }
.weather-info { font-size: 24rpx; opacity: 0.85; }
.grid-menu { display: flex; justify-content: space-around; background: #fff; border-radius: 16rpx; padding: 30rpx 0; margin-bottom: 20rpx; }
.grid-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.grid-icon { width: 64rpx; height: 64rpx; }
.section-title { font-size: 32rpx; font-weight: bold; margin-bottom: 16rpx; padding-left: 8rpx; border-left: 6rpx solid #2F5496; }
.announce-title { font-size: 28rpx; font-weight: 500; margin-bottom: 8rpx; }
.announce-meta { font-size: 24rpx; color: #999; display: flex; gap: 16rpx; }
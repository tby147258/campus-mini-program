/* app.wxss - 全局样式 */
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
}
.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}
button::after {
  border: none;
}